# ============================================================
# Growth Sales Academy LMS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# DATABASE — PostgreSQL connection string
# Used by Prisma and passed to the Next.js app container
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# ------------------------------------------------------------

# Local development (outside Docker) — port 5433 avoids conflict with native PostgreSQL
DATABASE_URL=postgresql://gsa_user:gsa_password@127.0.0.1:5433/gsa_db?schema=public

# Inside Docker Compose (app container connecting to db service) — use port 5432
# DATABASE_URL=postgresql://gsa_user:gsa_password@db:5432/gsa_db?schema=public

# ------------------------------------------------------------
# NEXTAUTH — Authentication secrets
# Docs: https://next-auth.js.org/configuration/options
# ------------------------------------------------------------

# Full URL of the deployed app (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Random secret used to sign JWT tokens — generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_a_strong_random_secret

# ------------------------------------------------------------
# NODE ENVIRONMENT
# ------------------------------------------------------------

NODE_ENV=development

# ------------------------------------------------------------
# ------------------------------------------------------------
# STRIPE — Payment processing
# Get these from: https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# CLOUDINARY — Image hosting (optional)
# Used for course thumbnails and hero images
# Get these from: https://cloudinary.com/console
# ------------------------------------------------------------

# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ------------------------------------------------------------
# BUNNY STREAM — Video hosting and streaming
# Get these from: https://dash.bunny.net/stream
# ------------------------------------------------------------

BUNNY_API_KEY=your_bunny_account_api_key
BUNNY_LIBRARY_ID=your_library_id
BUNNY_LIBRARY_API_KEY=your_library_api_key
BUNNY_CDN_HOSTNAME=vz-XXXXXXXX-XXX.b-cdn.net
NEXT_PUBLIC_BUNNY_LIBRARY_ID=your_library_id
