datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STUDENT
}

enum LessonType {
  VIDEO
  TEXT
  FORM
  EXAM
}

model User {
  id            String    @id @default(cuid())
  name          String
  last_name     String
  username      String    @unique
  phone         String?
  email         String    @unique
  password      String    // Hashed with bcrypt
  profile_image String?
  bio           String?   @db.Text
  title         String?              // Professional title: "Sales Coach", "Closer Senior"
  location      String?              // "CDMX, México"
  role          Role      @default(STUDENT)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  payment_status     String    @default("none")   // none | active | past_due | cancelled
  stripe_customer_id String?   @unique
  blocked            Boolean   @default(false)

  enrollments        Enrollment[]
  progress           LessonProgress[]
  notes              LessonNote[]
  instructed_courses Course[]          @relation("CourseInstructor")
  form_submissions   FormSubmission[]
  exam_attempts      ExamAttempt[]
  payments              Payment[]
  created_invitations   Invitation[] @relation("InvitationCreator")
  redeemed_invitations  Invitation[] @relation("InvitationRedeemer")
}

model Course {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  thumbnail   String?
  hero_image  String?
  price       Float?
  published     Boolean   @default(false)
  instructor_id String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  instructor  User?        @relation("CourseInstructor", fields: [instructor_id], references: [id], onDelete: SetNull)
  modules     Module[]
  enrollments Enrollment[]
}

model Module {
  id          String   @id @default(cuid())
  course_id   String
  title       String
  order       Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  course      Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons     Lesson[]
}

model Lesson {
  id            String     @id @default(cuid())
  module_id     String
  title         String
  description   String?    @db.Text
  type          LessonType @default(VIDEO)
  video_url      String?
  thumbnail      String?
  bunny_video_id String?
  bunny_status   String?   // 'processing' | 'ready' | 'failed'
  content       String?    @db.Text    // Rich text for TEXT lessons; intro text for FORM/EXAM
  form_schema   Json?                  // Form field definitions for FORM lessons
  exam_schema   Json?                  // Exam questions/options for EXAM lessons
  passing_score Int?                   // Minimum % to pass (EXAM only)
  max_attempts  Int?                   // Max retries (EXAM only, null = unlimited)
  is_final_exam Boolean    @default(false)
  order         Int
  duration      Int?       // In minutes
  resources     Json?      // Array of { id, name, url, type: 'link' | 'file' }
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  module           Module           @relation(fields: [module_id], references: [id], onDelete: Cascade)
  progress         LessonProgress[]
  notes            LessonNote[]
  form_submissions FormSubmission[]
  exam_attempts    ExamAttempt[]
}

model Enrollment {
  id          String    @id @default(cuid())
  user_id     String
  course_id   String
  approved    Boolean   @default(false)
  approved_at DateTime?
  created_at  DateTime  @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id])
}

model LessonProgress {
  id           String    @id @default(cuid())
  user_id      String
  lesson_id    String
  completed    Boolean   @default(false)
  completed_at DateTime?
  score        Int?      // Percentage score for EXAM lessons
  passed       Boolean?  // Whether the user passed the exam

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson       Lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id])
}

model LessonNote {
  id          String   @id @default(cuid())
  user_id     String
  lesson_id   String
  content     String   @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id])
}

model FormSubmission {
  id          String   @id @default(cuid())
  user_id     String
  lesson_id   String
  data        Json
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id])
}

model ExamAttempt {
  id          String   @id @default(cuid())
  user_id     String
  lesson_id   String
  answers     Json
  score       Int
  passed      Boolean
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@index([user_id, lesson_id])
}

model Payment {
  id                  String    @id @default(cuid())
  user_id             String
  stripe_checkout_id  String?   @unique
  payment_type        String    // one_time | installment
  amount              Int       // Amount for THIS payment in cents
  currency            String    @default("eur")
  status              String    @default("pending") // pending | completed | failed
  installment_number  Int?      // 1, 2, 3... null for one_time
  installment_plan_id String?   // Groups related installments together
  due_date            DateTime? // When this installment is due
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  user                User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([installment_plan_id])
}

model SiteSettings {
  id         String   @id @default("singleton")
  pricing    Json     // { totalPrice: 188800, firstInstallment: 188800, installmentCount: 1 }
  updated_at DateTime @updatedAt
}

model Invitation {
  id           String    @id @default(cuid())
  created_by   String
  payment_type String    // one_time | installment
  amount_paid  Int       // cents already paid externally
  installments Json?     // [{ number, amount, dueDate }] pending installments
  used         Boolean   @default(false)
  used_by      String?
  used_at      DateTime?
  expires_at   DateTime?
  created_at   DateTime  @default(now())

  creator      User      @relation("InvitationCreator", fields: [created_by], references: [id])
  redeemer     User?     @relation("InvitationRedeemer", fields: [used_by], references: [id])
}
